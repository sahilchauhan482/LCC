---
---
<div class="before-after reveal">
  <div class="ba-header">
    <h3>See the Difference</h3>
    <p>Drag the slider to see how we bring dead laptops back to life.</p>
  </div>
  
  <div class="slider-container" id="ba-slider">
    <!-- Before Image (Base) -->
    <img src="/before.png" alt="Broken Laptop" class="slider-img before-img" />
    <span class="label label-before">Before</span>
    
    <!-- After Image (Clipped) -->
    <div class="after-wrapper">
      <img src="/after.png" alt="Repaired Laptop" class="slider-img after-img" />
      <span class="label label-after">After</span>
    </div>
    
    <div class="slider-handle">
      <div class="slider-handle-button">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </div>
    </div>
  </div>
</div>

<script>
  const container = document.getElementById('ba-slider');
  const afterWrapper = container?.querySelector('.after-wrapper');
  const handle = container?.querySelector('.slider-handle');
  
  if (container && afterWrapper && handle) {
    let isDragging = false;
    
    const slide = (x) => {
      const rect = container.getBoundingClientRect();
      let percent = ((x - rect.left) / rect.width) * 100;
      percent = Math.max(0, Math.min(percent, 100));
      
      afterWrapper.style.clipPath = `inset(0 ${100 - percent}% 0 0)`;
      handle.style.left = `${percent}%`;
    };
    
    const startDrag = () => { isDragging = true; };
    const stopDrag = () => { isDragging = false; };
    const drag = (e) => {
      if (!isDragging) return;
      // e.preventDefault(); // Can interfere with scroll on mobile if not careful, but touch-action pan-y handles it
      const x = e.type.includes('mouse') ? e.clientX : e.touches[0].clientX;
      slide(x);
    };

    container.addEventListener('mousedown', startDrag);
    container.addEventListener('touchstart', startDrag, { passive: true });
    
    window.addEventListener('mouseup', stopDrag);
    window.addEventListener('touchend', stopDrag);
    
    window.addEventListener('mousemove', drag);
    window.addEventListener('touchmove', drag, { passive: true });
  }
</script>

<style>
  .before-after {
    margin-top: 5rem;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .ba-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  
  .ba-header h3 {
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--brand-black);
    margin-bottom: 0.5rem;
  }
  
  .ba-header p {
    color: var(--brand-muted);
    font-size: 1.1rem;
  }

  .slider-container {
    position: relative;
    width: 100%;
    max-width: 900px;
    aspect-ratio: 16 / 9; /* Responsive height */
    max-height: 500px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #fff;
    box-shadow: var(--shadow-card);
    border: 1px solid var(--brand-line);
    cursor: ew-resize;
    user-select: none;
    touch-action: pan-y; /* Allow vertical scroll, hijack horizontal */
  }

  .slider-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
  }
  
  .after-img {
    /* Blow out the slight off-white background to pure white so it perfectly matches the before image */
    filter: brightness(1.04) contrast(1.02);
  }

  .after-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    clip-path: inset(0 50% 0 0); /* Default 50% */
    z-index: 2;
  }

  .label {
    position: absolute;
    top: 1.5rem;
    padding: 0.4rem 1.2rem;
    background: rgba(0, 0, 0, 0.7);
    color: white;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 700;
    backdrop-filter: blur(4px);
    pointer-events: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    z-index: 3;
  }

  .label-before {
    right: 1.5rem;
  }

  .label-after {
    left: 1.5rem;
  }

  .slider-handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 4px;
    background: var(--brand-orange);
    z-index: 4;
    transform: translateX(-50%);
    pointer-events: none;
    box-shadow: 0 0 10px rgba(255, 94, 0, 0.5);
  }

  .slider-handle-button {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 48px;
    height: 48px;
    background: var(--brand-orange);
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    color: white;
    box-shadow: 0 4px 15px rgba(255, 94, 0, 0.4);
    border: 3px solid white;
    pointer-events: auto;
    transition: transform 0.2s;
  }

  .slider-container:hover .slider-handle-button {
    transform: translate(-50%, -50%) scale(1.05);
  }

  .slider-handle-button svg {
    width: 20px;
    height: 20px;
  }
  
  .slider-handle-button svg:first-child {
    margin-right: -2px;
  }
  
  .slider-handle-button svg:last-child {
    margin-left: -2px;
  }
</style>
