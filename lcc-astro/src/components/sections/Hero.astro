---
import Icon from '../ui/Icon.astro';
import { getSiteSettings } from '../../lib/sanity';

const settings = await getSiteSettings();
---

<section id="top" class="hero">
  <div class="container hero__grid">
    <!-- Left Column: Content -->
    <div class="hero__copy">
      <p class="eyebrow reveal" data-reveal-delay="100">
        <Icon name="arrow" size={16} /> Zirakpur · Punjab
      </p>
      <h1 class="hero__title">
        We rebuild your <span class="text-grad">laptop</span>,<br />part&nbsp;by&nbsp;part.
      </h1>
      <p class="hero__tag reveal" data-reveal-delay="600">{settings.tagline}</p>
      <div class="hero__cta reveal" data-reveal-delay="800">
        <a class="btn btn--primary" href="#contact">
          Book a repair <span class="btn__arrow" aria-hidden="true">↗</span>
        </a>
        <a class="btn btn--ghost hero__ghost" href="#services">See services</a>
      </div>
    </div>

    <!-- Right Column: Premium Workshop Photography -->
    <div class="hero__visual">
      <div class="visual__frame">
        <img 
          src="/hero_laptop.png" 
          alt="Premium Laptops Restoration Lakhdata Computer Care"
          class="visual__img"
        />
        
        <!-- Floating Status Widgets -->
        <div class="widget widget--tl">
          <span class="widget__icon widget__icon--green">✓</span>
          <div class="widget__body">
            <span class="widget__label">Diagnostics</span>
            <span class="widget__value">100% Complete</span>
          </div>
        </div>
        
        <div class="widget widget--tr">
          <span class="widget__icon widget__icon--purple">🔒</span>
          <div class="widget__body">
            <span class="widget__label">Data Recovery</span>
            <span class="widget__value">100% Secure</span>
          </div>
        </div>
        
        <div class="widget widget--mr">
          <span class="widget__icon widget__icon--orange">⚡</span>
          <div class="widget__body">
            <span class="widget__label">Motherboard</span>
            <span class="widget__value">Precision Fixed</span>
          </div>
        </div>

        <div class="widget widget--bl">
          <span class="widget__icon widget__icon--blue">💻</span>
          <div class="widget__body">
            <span class="widget__label">LCC Rentals</span>
            <span class="widget__value">Ready to Ship</span>
          </div>
        </div>
        
        <div class="widget widget--br">
          <span class="widget__icon widget__icon--red">📱</span>
          <div class="widget__body">
            <span class="widget__label">Screen Repair</span>
            <span class="widget__value">Same Day Fix</span>
          </div>
        </div>
        
        <div class="visual__glow" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  // --- 1. Split Text Character Splitting ---
  const title = document.querySelector('.hero__title');
  if (title) {
    const nodes = Array.from(title.childNodes);
    title.innerHTML = '';
    
    nodes.forEach(node => {
      if (node.nodeType === Node.TEXT_NODE) {
        const text = node.textContent || '';
        const frag = document.createDocumentFragment();
        for (let char of text) {
          const span = document.createElement('span');
          span.className = char.trim() ? 'char' : 'char char--space';
          span.textContent = char;
          frag.appendChild(span);
        }
        title.appendChild(frag);
      } else if (node.nodeName === 'BR') {
        title.appendChild(document.createElement('br'));
      } else {
        const spanNode = node.cloneNode(true) as HTMLElement;
        const text = spanNode.textContent || '';
        spanNode.innerHTML = '';
        for (let char of text) {
          const charSpan = document.createElement('span');
          charSpan.className = 'char text-grad';
          charSpan.textContent = char;
          spanNode.appendChild(charSpan);
        }
        title.appendChild(spanNode);
      }
    });

    // Animate letters rising up with scale, fade and blur
    gsap.fromTo('.char', 
      { opacity: 0, y: 25, filter: 'blur(3px)' },
      { opacity: 1, y: 0, filter: 'blur(0px)', duration: 0.7, stagger: 0.02, ease: 'power2.out', delay: 0.1 }
    );
  }

  // --- 2. Floating Animations for Widgets (Gentle Loop, no cursor interaction) ---
  gsap.to('.widget--tl', { y: -8, duration: 2.2, repeat: -1, yoyo: true, ease: 'sine.inOut' });
  gsap.to('.widget--tr', { y: 12, duration: 2.4, repeat: -1, yoyo: true, ease: 'sine.inOut', delay: 0.2 });
  gsap.to('.widget--mr', { y: 10, duration: 2.6, repeat: -1, yoyo: true, ease: 'sine.inOut', delay: 0.3 });
  gsap.to('.widget--bl', { y: -6, duration: 1.9, repeat: -1, yoyo: true, ease: 'sine.inOut', delay: 0.6 });
  gsap.to('.widget--br', { y: -10, duration: 2.1, repeat: -1, yoyo: true, ease: 'sine.inOut', delay: 0.5 });
</script>

<style>
  .hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding-block: clamp(5rem, 4rem + 5vw, 8rem);
    background: radial-gradient(100% 100% at 50% 0%, #FFFFFF 0%, var(--brand-paper) 100%);
    overflow: hidden;
    position: relative;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(2rem, 1rem + 5vw, 5rem);
    align-items: center;
    width: 100%;
  }

  .hero__copy {
    position: relative;
    text-align: left;
    max-width: 580px;
    z-index: 2;
  }

  .hero__copy .eyebrow {
    color: var(--brand-orange);
    justify-content: flex-start;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hero__title {
    font-size: clamp(2.2rem, 1.2rem + 3.8vw, 4.2rem);
    color: var(--brand-black, #000000);
    margin-top: 0.8rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: var(--tracking-tight);
  }

  /* Split text char styles */
  :global(.char) {
    display: inline-block;
    will-change: transform, opacity, filter;
  }
  :global(.char--space) {
    width: 0.25em;
  }

  .text-grad {
    background: var(--grad-hero);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero__tag {
    margin: 1.5rem 0 0;
    max-width: 48ch;
    color: var(--brand-muted, #575762);
    font-size: var(--text-base);
    line-height: 1.6;
  }

  .hero__cta {
    margin-top: 2.5rem;
    display: flex;
    gap: 1rem;
    justify-content: flex-start;
    flex-wrap: wrap;
  }

  .hero__ghost {
    color: var(--brand-black, #000000);
    border-color: rgba(0, 0, 0, 0.15);
  }

  .hero__ghost:hover {
    color: var(--brand-orange);
    border-color: var(--brand-orange);
    background: var(--brand-orange-soft);
  }

  /* Right Column Visual */
  .hero__visual {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
    z-index: 2;
  }

  .visual__frame {
    position: relative;
    width: 100%;
    max-width: 460px;
  }

  .visual__img {
    width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
    aspect-ratio: 4/3;
    z-index: 5;
  }

  .visual__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(255, 94, 0, 0.08) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  /* Parallax Floating Widgets styling (Global classes to guarantee rendering) */
  :global(.widget) {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.6rem 1rem;
    background: rgba(255, 255, 255, 0.95) !important;
    backdrop-filter: blur(12px);
    border: 1px solid rgba(0, 0, 0, 0.08) !important;
    border-radius: var(--radius);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.06);
    pointer-events: none;
    z-index: 10;
    will-change: transform;
  }

  :global(.widget--tl) {
    top: 5%;
    left: -12%;
  }

  :global(.widget--tr) {
    top: -2%;
    right: -2%;
  }

  :global(.widget--mr) {
    top: 40%;
    right: -15%;
  }

  :global(.widget--bl) {
    bottom: 8%;
    left: -8%;
  }

  :global(.widget--br) {
    bottom: -2%;
    right: 8%;
  }

  :global(.widget__icon) {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    font-size: 0.9rem;
    font-weight: bold;
  }
  
  :global(.widget__icon--green) {
    background: #EAFCEF;
    color: #10B981;
  }
  
  :global(.widget__icon--orange) {
    background: var(--brand-orange-soft);
    color: var(--brand-orange);
  }
  
  :global(.widget__icon--blue) {
    background: #EBF5FF;
    color: #3B82F6;
  }
  
  :global(.widget__icon--purple) {
    background: #F3E8FF;
    color: #A855F7;
  }
  
  :global(.widget__icon--red) {
    background: #FEE2E2;
    color: #EF4444;
  }
  
  :global(.widget__body) {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    text-align: left;
  }
  
  :global(.widget__label) {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--brand-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  :global(.widget__value) {
    display: inline-block;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--brand-black);
  }

  /* Responsive layout */
  @media (max-width: 768px) {
    .hero__grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3.5rem;
    }
    .hero__copy {
      margin-inline: auto;
      text-align: center;
    }
    .hero__copy .eyebrow {
      justify-content: center;
    }
    .hero__cta {
      justify-content: center;
    }
    .hero__visual {
      max-width: 360px;
      margin-inline: auto;
    }
    :global(.widget) {
      padding: 0.5rem 0.8rem;
    }
    :global(.widget--tl) {
      left: -5%;
      top: 0%;
    }
    :global(.widget--mr) {
      right: -8%;
      top: 35%;
    }
    :global(.widget--bl) {
      left: -2%;
      bottom: 0%;
    }
    :global(.widget--tr), :global(.widget--br) {
      display: none; /* Hide extra widgets on small screens to prevent clutter */
    }
  }
</style>
