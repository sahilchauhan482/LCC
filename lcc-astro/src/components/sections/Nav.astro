---
import Icon from '../ui/Icon.astro';
import { site, nav } from '../../data/site';
---

<header class="nav" data-nav>
  <div class="container nav__inner">
    <a class="nav__brand" href="#top" aria-label={`${site.name} home`}>
      <img src="/logo.jpg" alt="" width="120" height="38" class="nav__logo" />
    </a>

    <nav class="nav__links" aria-label="Primary">
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <a class="btn btn--primary nav__cta" href={`tel:${site.phoneHref}`}>
      <Icon name="phone" size={16} />
      <span class="nav__phone">{site.phoneDisplay}</span>
    </a>
  </div>
</header>

<script>
  // Solidify the nav on scroll.
  const nav = document.querySelector('[data-nav]');
  const onScroll = () => nav?.classList.toggle('is-stuck', window.scrollY > 24);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    transition:
      background var(--dur-normal),
      box-shadow var(--dur-normal),
      border-color var(--dur-normal);
    border-bottom: 1px solid transparent;
  }
  .nav.is-stuck {
    background: var(--brand-white);
    border-bottom-color: var(--brand-line);
    box-shadow: 0 6px 24px rgba(20, 20, 20, 0.05);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 72px;
  }
  .nav__logo {
    height: 52px;
    width: auto;
  }
  .nav__links {
    display: flex;
    gap: 1.8rem;
    margin-left: auto;
    margin-right: 0.5rem;
  }
  .nav__links a {
    position: relative;
    font-weight: 500;
    font-size: var(--text-sm);
    color: var(--brand-text);
    padding-block: 0.4rem;
  }
  .nav__links a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 2px;
    background: var(--grad-hero);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur-normal) var(--ease-out-expo);
  }
  .nav__links a:hover::after {
    transform: scaleX(1);
  }
  @media (max-width: 760px) {
    .nav__links {
      display: none;
    }
    .nav__phone {
      display: none;
    }
    .nav__cta {
      padding: 0.8em 1em;
    }
  }
</style>
