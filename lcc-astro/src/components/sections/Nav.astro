---
import Icon from '../ui/Icon.astro';
import { site, nav } from '../../data/site';

const isHome = Astro.url.pathname === '/';

interface Props {
  forceDarkText?: boolean;
}
const { forceDarkText = false } = Astro.props;
---

<header class={`nav ${!isHome ? 'nav--subpage' : ''} ${forceDarkText ? 'nav--dark-text' : ''}`} data-nav>
  <div class="container nav__inner">
    <a class="nav__brand" href="/" aria-label={`${site.name} home`}>
      <img src="/logo.jpg" alt="" width="120" height="38" class="nav__logo" />
    </a>

    <nav class="nav__links" aria-label="Primary">
      {nav.map((item) => (
        item.submenu ? (
          <div class="nav__dropdown">
            <a href={item.href} class="nav__dropdown-toggle">
              {item.label}
              <span class="nav__dropdown-icon">
                <Icon name="arrow" size={10} />
              </span>
            </a>
            <div class="nav__dropdown-menu">
              {item.submenu.map((sub) => (
                <a href={sub.href} class="nav__dropdown-item">{sub.label}</a>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href}>{item.label}</a>
        )
      ))}
    </nav>

    <a class="btn btn--primary nav__cta" href={`tel:${site.phoneHref}`}>
      <Icon name="phone" size={16} />
      <span class="nav__phone">{site.phoneDisplay}</span>
    </a>
  </div>
</header>

<script>
  // Solidify the nav on scroll.
  const nav = document.querySelector('[data-nav]');
  const onScroll = () => nav?.classList.toggle('is-stuck', window.scrollY > 24);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    transition:
      background var(--dur-normal),
      box-shadow var(--dur-normal),
      border-color var(--dur-normal);
    border-bottom: 1px solid transparent;
  }
  .nav.is-stuck {
    background: var(--brand-white);
    border-bottom-color: var(--brand-line);
    box-shadow: 0 6px 24px rgba(20, 20, 20, 0.05);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 72px;
  }
  .nav__logo {
    height: 52px;
    width: auto;
  }
  .nav__links {
    display: flex;
    gap: 1.8rem;
    margin-left: auto;
    margin-right: 0.5rem;
  }
  .nav__links a {
    position: relative;
    font-weight: 500;
    font-size: var(--text-sm);
    color: var(--brand-text);
    padding-block: 0.4rem;
    transition: color var(--dur-fast);
  }
  .nav__links a:hover {
    color: var(--brand-orange);
  }
  .nav--subpage:not(.is-stuck):not(.nav--dark-text) .nav__links a {
    color: var(--brand-white);
  }
  .nav--subpage:not(.is-stuck):not(.nav--dark-text) .nav__links a:hover {
    color: var(--brand-orange-soft);
  }
  .nav__links a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 2px;
    background: var(--grad-hero);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur-normal) var(--ease-out-expo);
  }
  .nav__links a:hover::after {
    transform: scaleX(1);
  }

  /* Dropdown Menu Styles */
  .nav__dropdown {
    position: relative;
    display: inline-block;
  }
  .nav__dropdown-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .nav__dropdown-icon {
    display: inline-block;
    transition: transform var(--dur-fast);
    transform: rotate(135deg); /* Arrow points up-right, rotate 135deg makes it point down */
  }
  .nav__dropdown:hover .nav__dropdown-icon {
    transform: rotate(-45deg); /* Point up on hover */
    color: var(--brand-orange);
  }
  .nav__dropdown-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: var(--brand-white);
    border: 1px solid var(--brand-line);
    border-radius: var(--radius-sm);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    padding: 0.6rem 0;
    min-width: 270px;
    display: flex;
    flex-direction: column;
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      transform var(--dur-normal) var(--ease-out-expo),
      opacity var(--dur-normal),
      visibility var(--dur-normal);
  }
  .nav__dropdown:hover .nav__dropdown-menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }
  .nav__dropdown-item {
    padding: 0.6rem 1.4rem;
    color: var(--brand-text) !important; /* Ensure it stays dark even on transparent subpage nav */
    font-size: var(--text-sm) !important;
    font-weight: 500;
    text-align: left;
    transition: background var(--dur-fast), color var(--dur-fast) !important;
    white-space: nowrap;
  }
  .nav__dropdown-item::after {
    display: none !important;
  }
  .nav__dropdown-item:hover {
    background: var(--brand-paper) !important;
    color: var(--brand-orange) !important;
  }

  @media (max-width: 760px) {
    .nav__links {
      display: none;
    }
    .nav__phone {
      display: none;
    }
    .nav__cta {
      padding: 0.8em 1em;
    }
  }
</style>
