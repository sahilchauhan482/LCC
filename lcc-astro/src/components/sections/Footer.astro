---
import SocialIcons from '../ui/SocialIcons.astro';
import { site, nav } from '../../data/site';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__grid">
    <div class="footer__brand">
      <img src="/logo.jpg" alt={site.name} width="140" height="44" class="footer__logo" />
      <p class="footer__tag">{site.tagline}</p>
      <SocialIcons tone="dark" />
    </div>

    <nav class="footer__col" aria-label="Footer">
      <h4>Explore</h4>
      <ul>
        {nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>

    <div class="footer__col">
      <h4>Visit</h4>
      <address class="footer__addr">
        {site.address.line1}<br />
        {site.address.city}, {site.address.region} {site.address.postal}
      </address>
      <a class="footer__phone" href={`tel:${site.phoneHref}`}>{site.phoneDisplay}</a>
    </div>

    <div class="footer__col">
      <h4>Hours</h4>
      <ul class="footer__hours">
        {site.hours.map((h) => <li><span>{h.day}</span><span>{h.time}</span></li>)}
      </ul>
    </div>
  </div>

  <div class="container footer__bar">
    <p>© {year} {site.name}. All rights reserved.</p>
    <p>Made with care in Zirakpur · Punjab</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--brand-ink);
    color: rgba(255, 255, 255, 0.8);
    padding-top: clamp(3rem, 2rem + 3vw, 5rem);
  }
  .footer p, 
  .footer address, 
  .footer span {
    color: rgba(255, 255, 255, 0.8);
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 0.8fr 1.7fr 1.2fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }
  .footer__logo {
    /* Invert black/white while keeping orange, then screen the black out */
    filter: invert(1) hue-rotate(180deg) contrast(1.2);
    mix-blend-mode: screen;
    height: 60px;
    width: auto;
  }
  .footer__tag {
    margin: 1rem 0 1.4rem;
    max-width: 34ch;
    color: rgba(255, 255, 255, 0.8);
    font-size: var(--text-sm);
  }
  .footer__col h4 {
    color: #fff;
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }
  .footer__col ul {
    display: grid;
    gap: 0.6rem;
  }
  .footer__col a {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-sm);
    transition: color var(--dur-fast);
  }
  .footer__col a:hover {
    color: var(--brand-orange);
  }
  .footer__addr {
    font-style: normal;
    font-size: var(--text-sm);
    line-height: 1.7;
  }
  .footer__phone {
    display: inline-block;
    margin-top: 0.8rem;
    font-weight: 700;
    color: #fff;
  }
  .footer__phone:hover {
    color: var(--brand-orange);
  }
  .footer__hours li {
    display: flex;
    gap: 0.75rem;
    font-size: var(--text-sm);
    padding-block: 0.3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    white-space: nowrap;
  }
  .footer__hours li span:first-child {
    flex: 0 0 4.5rem;
  }
  .footer__bar {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-block: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.82rem;
  }
  .footer__bar p {
    color: rgba(255, 255, 255, 0.9);
  }
  @media (max-width: 860px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 480px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
