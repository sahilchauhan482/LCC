---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/sections/Nav.astro';
import Footer from '../components/sections/Footer.astro';
import Icon from '../components/ui/Icon.astro';
import ReviewMarquee from '../components/ui/ReviewMarquee.astro';
import BeforeAfter from '../components/ui/BeforeAfter.astro';

const pageTitle = "About Lakhdata Computer Care — Trust & Quality Repair";
const pageDescription = "Learn about Lakhdata Computer Care in Zirakpur, Punjab: over 15 years of expert hardware repairs, diagnostic lab, and refurbished sales.";

const values = [
  {
    icon: "shield",
    title: "Absolute Honesty",
    desc: "We diagnose first and quote upfront. If a chip is repairable, we repair it rather than suggesting a full board replacement. We never upsell or suggest repairs that are not needed."
  },
  {
    icon: "sparkles",
    title: "Benchmark Quality",
    desc: "We use only genuine OEM parts or tested grade-A spares. Every soldering joint, thermal repaste, and screen adhesive is applied with rigorous attention to detail."
  },
  {
    icon: "clock",
    title: "Fast Turnaround",
    desc: "We know your system is vital for your work. Most upgrades, screen replacements, and cleaning services are finished on the same day. Motherboard repairs are completed in 24-48 hours."
  }
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Nav />
  
  <main id="main">
    <!-- About Premium Hero -->
    <header class="sub-hero">
      <div class="sub-hero__bg" style="background-image: linear-gradient(180deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.4) 60%, var(--brand-white) 100%), url('/about_shop.png');"></div>
      <div class="container sub-hero__content">
        <p class="eyebrow">Who we are</p>
        <h1 class="sub-hero__title">About Lakhdata Computer Care</h1>
        <p class="sub-hero__lead">
          For over 15 years, Zirakpur locals have trusted LCC for honest diagnostics, master-level hardware repair, and reliable hardware sales.
        </p>
      </div>
    </header>

    <!-- Company Story Section -->
    <section class="section about-story">
      <div class="container about-story__grid">
        <div class="about-story__text reveal">
          <p class="eyebrow">Our history</p>
          <h2>Crafting trust in Zirakpur since 2011.</h2>
          <p>
            Lakhdata Computer Care (LCC) was founded on a simple principle: **do repair right**. In an industry often filled with guesswork, temporary fixes, and exaggerated prices, we chose a different path. 
          </p>
          <p>
            We invested in high-end diagnostic tools, high-magnification microscopes, and professional BGA rework stations. This allows our technicians to solve complex, component-level motherboard faults that most general repair shops write off as unfixable.
          </p>
          <p>
            Today, LCC is Zirakpur’s go-to destination for high-end repair, custom-configured refurbished computer sales, and convenient rental setups. We serve individual users, students, and businesses across the Tricity area with the same dedication.
          </p>
          
          <ul class="stats-row">
            <li>
              <span class="stats-num text-grad"><span class="counter" data-target="10">0</span>K+</span>
              <span class="stats-label">Repairs Completed</span>
            </li>
            <li>
              <span class="stats-num text-grad"><span class="counter" data-target="15">0</span>+</span>
              <span class="stats-label">Years Experience</span>
            </li>
            <li>
              <span class="stats-num text-grad"><span class="counter" data-target="99">0</span>%</span>
              <span class="stats-label">Happy Customers</span>
            </li>
          </ul>
        </div>
        
        <div class="about-story__side reveal" data-reveal-delay={100}>
          <div class="lab-card">
            <h3>Our Repair Standards</h3>
            <ul class="lab-list">
              <li>
                <span class="lab-icon"><Icon name="board" size={18} /></span>
                <div>
                  <strong>Chip-Level Precision</strong>
                  <p>Micro-soldering, SMD replacement, and IC trace repairs done in-house.</p>
                </div>
              </li>
              <li>
                <span class="lab-icon"><Icon name="shield" size={18} /></span>
                <div>
                  <strong>OEM Spares Only</strong>
                  <p>Genuine screens, solid state drives, and power components with guarantees.</p>
                </div>
              </li>
              <li>
                <span class="lab-icon"><Icon name="sparkles" size={18} /></span>
                <div>
                  <strong>Comprehensive Testing</strong>
                  <p>15-point diagnostic checks before any device is handed back to its owner.</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Core Values Section -->
    <section class="section values-section">
      <div class="container">
        <div class="section-head reveal">
          <p class="eyebrow">Our Values</p>
          <h2>The principles that guide our work.</h2>
          <p class="section-lead">
            We hold ourselves to a higher benchmark of repair and service, ensuring transparency and quality for every user.
          </p>
        </div>

        <div class="values-grid">
          {values.map((v, i) => (
            <div class="value-item reveal" data-reveal-delay={i * 80}>
              <span class="value-item__icon"><Icon name={v.icon} size={24} /></span>
              <h3>{v.title}</h3>
              <p>{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Reviews Marquee -->
    <ReviewMarquee />

    <!-- Before & After Comparison -->
    <section class="section before-after-sec">
      <div class="container">
        <div class="section-head reveal">
          <p class="eyebrow">Visual proof</p>
          <h2>Before & after our workbench.</h2>
          <p class="section-lead">
            Hover or slide to see the difference between a dust-clogged, overheated motherboard and our clean, freshly-serviced motherboard rebuild.
          </p>
        </div>
        <BeforeAfter />
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Statistics counters animation
  const counters = document.querySelectorAll('.counter');
  counters.forEach((counter) => {
    const target = parseInt(counter.getAttribute('data-target') || '0', 10);
    
    gsap.fromTo(counter,
      { textContent: '0' },
      {
        textContent: String(target),
        duration: 1.8,
        ease: 'power2.out',
        snap: { textContent: 1 },
        scrollTrigger: {
          trigger: counter,
          start: 'top 85%',
          toggleActions: 'play none none none'
        }
      }
    );
  });
</script>

<style>
  /* Sub-Hero Header */
  .sub-hero {
    position: relative;
    padding-top: calc(72px + 4rem); /* Nav height + padding */
    padding-bottom: 6rem;
    color: var(--brand-white);
    overflow: hidden;
    min-height: 480px;
    display: flex;
    align-items: flex-end;
  }
  
  .sub-hero__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: 0;
    transform: scale(1.02);
  }
  
  .sub-hero__content {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }
  
  .sub-hero__title {
    font-size: clamp(2.5rem, 1.5rem + 5vw, 4.5rem);
    color: var(--brand-white);
    margin-block: 0.8rem 1.2rem;
  }
  
  .sub-hero__lead {
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
  }

  /* About Story Section */
  .about-story {
    background: var(--brand-white);
  }
  
  .about-story__grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(2rem, 1rem + 5vw, 5rem);
    align-items: center;
  }
  
  .about-story__text {
    display: grid;
    gap: 1.2rem;
  }
  
  .about-story__text h2 {
    font-size: var(--text-h2);
    margin-bottom: 0.5rem;
  }
  
  .about-story__text p {
    color: var(--brand-muted);
    font-size: var(--text-base);
    line-height: 1.65;
  }
  
  .stats-row {
    display: flex;
    gap: clamp(1.5rem, 1rem + 3vw, 3.5rem);
    margin-top: 1.5rem;
  }
  
  .stats-row li {
    display: grid;
    gap: 0.2rem;
  }
  
  .stats-num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2rem, 1.2rem + 3vw, 3.2rem);
    line-height: 1;
  }
  
  .stats-label {
    font-size: var(--text-sm);
    color: var(--brand-muted);
    font-weight: 500;
  }

  /* Laboratory Side Card */
  .lab-card {
    background: var(--brand-paper);
    border: 1px solid var(--brand-line);
    border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 1rem + 2vw, 2.5rem);
    box-shadow: var(--shadow-card);
  }
  
  .lab-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--brand-black);
    margin-bottom: 1.5rem;
  }
  
  .lab-list {
    display: grid;
    gap: 1.5rem;
  }
  
  .lab-list li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  
  .lab-icon {
    flex: none;
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    color: #fff;
    background: var(--grad-hero);
  }
  
  .lab-list strong {
    display: block;
    font-size: 0.95rem;
    color: var(--brand-black);
    margin-bottom: 0.2rem;
  }
  
  .lab-list p {
    font-size: var(--text-sm);
    color: var(--brand-muted);
    line-height: 1.45;
  }

  /* Core Values Grid */
  .values-section {
    background: var(--brand-paper);
    border-top: 1px solid var(--brand-line);
    border-bottom: 1px solid var(--brand-line);
  }
  
  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }
  
  .value-item {
    background: var(--brand-white);
    border: 1px solid var(--brand-line);
    border-radius: var(--radius);
    padding: 2.2rem 2rem;
    display: grid;
    gap: 1rem;
    transition: transform var(--dur-normal) var(--ease-out-expo), border-color var(--dur-normal);
  }
  
  .value-item:hover {
    transform: translateY(-4px);
    border-color: var(--brand-orange-soft);
  }
  
  .value-item__icon {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 10px;
    color: var(--brand-orange-deep);
    background: color-mix(in srgb, var(--brand-orange) 12%, white);
  }
  
  .value-item h3 {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--brand-black);
  }
  
  .value-item p {
    font-size: var(--text-sm);
    color: var(--brand-muted);
    line-height: 1.55;
  }

  /* Before After Section Wrapper */
  .before-after-sec {
    background: var(--brand-white);
  }

  /* Responsive Styling */
  @media (max-width: 860px) {
    .about-story__grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
